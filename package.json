{
  "name": "1ilsang.dev",
  "packageManager": "pnpm@11.3.0",
  "private": true,
  "version": "0.0.0",
  "author": "1ilsang <1ilsang.dev@gmail.com>",
  "description": "https://1ilsang.dev",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "node --experimental-strip-types ./scripts/pre-scripts.ts",
    "dev": "next dev",
    "build": "pnpm predev && next build",
    "start": "npx -y serve out",
    "tr": "turbo run",
    "lint:stylelint": "stylelint --config './.stylelintrc.cjs' './src/**/*.css'",
    "lint:prettier": "prettier --check './src/**/*.{json,html,yml,tsx,ts,js,jsx,css}' './_posts/**/*.{mdx,md}'",
    "lint:eslint": "eslint",
    "lint:markdown": "markdownlint --config './.markdownlint.cjs' './_posts/**/*.mdx'",
    "lint:cspell": "cspell lint --no-progress",
    "lint:typeCheck": "next typegen && tsc --pretty",
    "lint": "pnpm tr lint:eslint lint:typeCheck lint:stylelint lint:prettier lint:markdown lint:cspell",
    "e2e:build": "pnpm predev && NEXT_PUBLIC_E2E=true next build",
    "e2e:update:screen": "pnpm tr e2e:update:screen:run",
    "e2e:update:dom": "pnpm tr e2e:update:dom:run",
    "e2e:update:screen:run": "pnpm playwright test --grep '@screen-snapshot' --update-snapshots",
    "e2e:update:dom:run": "pnpm playwright test --grep '@dom-snapshot' --update-snapshots",
    "e2e:update:run": "pnpm playwright test --update-snapshots",
    "e2e:update": "pnpm tr e2e:update:run",
    "e2e:report": "pnpm exec playwright show-report",
    "e2e:install": "pnpm exec playwright install --with-deps",
    "e2e:others": "pnpm playwright test --grep-invert /@/",
    "e2e:dom": "pnpm playwright test --grep '@dom-snapshot'",
    "e2e:screen": "pnpm playwright test --grep '@screen-snapshot'",
    "e2e": "pnpm playwright test",
    "jest:watch": "jest --watch",
    "jest": "pnpm tr jest:run",
    "jest:run": "jest",
    "np": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/new-post.ts",
    "clean": "rm -rf .next out node_modules test-results coverage playwright-report",
    "knip": "pnpm dlx knip",
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.6",
    "@vercel/analytics": "^1.4.1",
    "@vercel/speed-insights": "^1.1.0",
    "classnames": "^2.5.1",
    "jotai": "^2.9.0",
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/mdx": "^2.0.13",
    "@types/node": "22.15.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cspell": "^10.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "estree-util-value-to-estree": "^3.2.1",
    "github-slugger": "^2.0.0",
    "husky": "9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "markdownlint": "0.38.0",
    "markdownlint-cli": "0.45.0",
    "postcss": "^8.4.39",
    "prettier": "3.5.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-mdx-frontmatter": "^5.0.0",
    "remark-rehype": "^11.1.0",
    "stylelint": "^16.7.0",
    "tailwindcss": "4.3.3",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.14",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.0.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  }
}
